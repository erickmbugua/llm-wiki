# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit it.

# OpenRouter — https://openrouter.ai/keys
# Set this to use any openrouter/<model> string in your vault config.
OPENROUTER_API_KEY=

# Optional: override the Ollama server URL if it's not on localhost:11434
# OLLAMA_API_BASE=http://192.168.1.10:11434

# Optional: OpenAI key if using openai/* models via litellm
# OPENAI_API_KEY=
